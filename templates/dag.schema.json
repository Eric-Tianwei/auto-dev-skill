{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "auto-dev/dag.schema.json",
  "title": "auto-dev DAG (v2, minimal)",
  "description": "Orchestration skeleton only. Node specs live in .auto-dev/nodes/<id>.md. The validator checks structural collapse, not semantic quality — the AI judges graph correctness itself.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "base_branch", "upstream_branch", "nodes", "edges"],
  "properties": {
    "version": { "const": 2 },
    "base_branch": { "type": "string", "minLength": 1 },
    "upstream_branch": { "type": "string", "minLength": 1 },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "status": { "enum": ["pending", "dev", "done", "blocked", "abandoned"] },
          "completion_tag": { "type": ["string", "null"] }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" }
        }
      }
    },
    "or_groups": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "candidates"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "candidates": {
            "type": "array",
            "minItems": 2,
            "items": { "type": "string" }
          },
          "decided": { "type": ["string", "null"] },
          "rejected": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
